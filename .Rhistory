adiciona_totais_evitaveis("evitaveis_perinatal")
df_evitaveis_perinatal_antes <- cria_grupo_evitavel(df_obitos_fetais_em_hospital, lista_cids_evitaveis, "evitaveis_perinatal_antes", filtro_obitoparto = 1)
